# =============================================================================
# MEIN HEADSHOP – Umgebungsvariablen (Kopie als .env.local, Werte eintragen)
# =============================================================================

# --- Supabase (Pflicht) ---
NEXT_PUBLIC_SUPABASE_URL=https://dein-projekt.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service-Role: Supabase → Project Settings → API → service_role (geheim halten!)

# --- Site (Pflicht) ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Produktion: https://deine-domain.de
# Mollie-Webhook braucht erreichbare URL (lokal: ngrok → MOLLIE_WEBHOOK_URL setzen)

NEXT_PUBLIC_SITE_NAME=Premium Headshop

# --- Inhaber-Admin ---
# E-Mail mit vollem Admin-Zugriff ohne Staff-Eintrag
ADMIN_OWNER_EMAIL=inhaber@example.de

# --- Mollie (Zahlung) ---
MOLLIE_API_KEY=test_... oder live_...
# Webhook-URL (Produktion = NEXT_PUBLIC_SITE_URL; lokal z.B. ngrok)
# MOLLIE_WEBHOOK_URL=https://xxxx.ngrok.io/api/payment/webhook
MOLLIE_WEBHOOK_SECRET=whsec_...
# Mollie Dashboard → Webhooks → Roll secret
# MOLLIE_SPLIT_ENABLED=true
# Split-Payments: Muss bei Mollie aktiviert werden. Vendoren brauchen mollie_organization_id in vendor_accounts.
# Mollie Connect (OAuth2) – Vendor-Organisation für Split verknüpfen (Admin: Vendor-Detail → „Mit Mollie verbinden“)
# MOLLIE_CONNECT_CLIENT_ID=app_...
# MOLLIE_CONNECT_CLIENT_SECRET=...   # Redirect-URI: {NEXT_PUBLIC_SITE_URL}/api/admin/mollie-connect/callback

# --- E-Mail (Resend) ---
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=Shop-Name <support@deine-domain.de>
# Inbound (Support-Antworten, Beschwerden): Domain + Reply-Prefixe
# RESEND_INBOUND_DOMAIN=mg.deine-domain.de
# RESEND_INBOUND_REPLY_PREFIX=reply         # Kundenanfragen: reply+{id}@domain
# RESEND_INBOUND_COMPLAINT_PREFIX=beschwerde # Beschwerden: beschwerde+{id}@domain

# --- Rechnung / Impressum / Footer (UStG, DDG) ---
INVOICE_COMPANY_NAME=Dein Firmenname
# Vertreten durch (Impressum), z. B. "Max Mustermann, Geschäftsführer"
COMPANY_REPRESENTED_BY=Geschäftsführer
INVOICE_COMPANY_ADDRESS=Straße Hausnr.
INVOICE_POSTAL_CODE=12345
INVOICE_CITY=Berlin
INVOICE_COUNTRY=Deutschland
INVOICE_VAT_ID=DE123456789
INVOICE_EMAIL=support@deine-domain.de
INVOICE_PHONE=+49 30 12345678
SUPPORT_HOURS=Mo–Fr 10–18 Uhr

# --- Lieferzeiten (Cart/Checkout) ---
NEXT_PUBLIC_DELIVERY_ESTIMATE_DAYS=2–4 Werktage

# --- Session (optional) ---
# Abmeldung nach X Min Inaktivität; beide auf gleichen Wert setzen
# SESSION_MAX_AGE_MINUTES=30
# NEXT_PUBLIC_SESSION_MAX_AGE_MINUTES=30

# --- Cron-Jobs ---
# Alle Cron-Routen: ?secret=CRON_SECRET (send-review-requests, auto-cancel-unpaid, sync-products, check-tracking)
CRON_SECRET=ein-sicheres-geheimes-passwort

# --- Lieferanten-Tracking ---
# Token für POST /api/supplier/tracking (Authorization: Bearer <token>)
SUPPLIER_TRACKING_SECRET=token-fuer-lieferanten

# --- Altersverifizierung (AVS) ---
# simulation = Sofort-Freigabe für Entwicklung (Standard)
# idnow, postident, qbit = echte Provider (API-Keys separat erforderlich)
AGE_VERIFICATION_PROVIDER=simulation
# AVS_AUDIT_SECRET=zufälliger-String (Hash für compliance.age_verification_logs)
# IDNOW_API_KEY=...
# POSTIDENT_API_KEY=...
# SCHUFA_QBIT_API_KEY=...

# --- DHL Parcel DE Shipping API (Labels, VisualCheckOfAge) ---
# DHL Developer Portal: https://developer.dhl.com/api-reference/parcel-de-shipping-post-parcel-germany-v2
# DHL_API_KEY=client_id (API Key)
# DHL_API_SECRET=client_secret (API Secret)
# DHL_GKP_USERNAME=GKP-Benutzername (Sandbox: user-valid)
# DHL_GKP_PASSWORD=GKP-Passwort (Sandbox: SandboxPasswort2023!)
# DHL_BILLING_NUMBER=14-stellig (EKP+Produkt+Teilnahme, z.B. 12345678905301)
# DHL_SANDBOX=true
# DHL_SHIPPER_NAME=Firmenname
# DHL_SHIPPER_STREET=Straßenname
# DHL_SHIPPER_HOUSE_NUMBER=42
# DHL_SHIPPER_POSTAL_CODE=12345
# DHL_SHIPPER_CITY=Berlin
# DHL_SHIPPER_COUNTRY=DEU
# DHL_DEFAULT_WEIGHT_KG=2

# --- reCAPTCHA (Kontaktformular, Passwort vergessen, optional) ---
# https://www.google.com/recaptcha/admin → reCAPTCHA v2
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6Lc...
# RECAPTCHA_SECRET_KEY=6Lc...

# --- Trust-Siegel (Footer, optional) ---
# NEXT_PUBLIC_TRUSTED_SHOPS_BADGE_URL=https://...
# NEXT_PUBLIC_EHI_SIEGEL_URL=https://...

# --- AI Newsletter (Admin → Marketing → Newsletter, optional) ---
# OPENAI_API_KEY=sk-...
# Test-Versand: Empfänger in site_settings eintragen (key: newsletter_test_email), z. B. in Admin → Einstellungen oder direkt in der Tabelle site_settings.

# --- Sentry (Error-Tracking, optional) ---
# https://sentry.io → Projekt erstellen → DSN kopieren
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
# Für Source-Map-Upload (CI/Vercel):
# SENTRY_ORG=dein-org-slug
# SENTRY_PROJECT=dein-projekt-slug
# SENTRY_AUTH_TOKEN=sntrys_...  (Sentry → Settings → Auth Tokens)

# --- Analytics & Server-Side Tracking (optional) ---
# NEXT_PUBLIC_GA_ID=G-...
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=deine-domain.de
# GTM Server Container: Collect-URL (z. B. Stape/GA4 Measurement Protocol). Events von /api/tracking/event werden dorthin weitergeleitet.
# GTM_SERVER_COLLECT_URL=https://xxx.container.server.com/collect
